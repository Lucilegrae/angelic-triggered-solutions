# ✦ Ritualized Git Ignore ✦

# Local Netlify folder
.netlify

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
node_modules
dist
dist-ssr

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vercel
.vercel

# ── ATS Covenant: Protect Secrets ──
# Ignore environment glyphs
.env              # keep backend secrets private
.env.*.local      # ignore variant env files
!.env.local       # explicitly keep frontend env tracked

# Ignore node modules (ritual dependencies)
node_modules/

# Ignore build artifacts
dist/
build/

# Ignore OS clutter
.DS_Store
Thumbs.db
